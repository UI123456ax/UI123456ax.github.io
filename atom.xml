        <id>https://ui123456ax.github.io/2023/06/23/%E5%9B%BE%E5%BA%8A%E4%BF%AE%E5%A4%8D/</id>
        <title>图床修复</title>
        <link rel="alternate" href="https://ui123456ax.github.io/2023/06/23/%E5%9B%BE%E5%BA%8A%E4%BF%AE%E5%A4%8D/"/>
        <content type="html">&lt;p&gt;在 engine.js 文件内修改&lt;br /&gt;
 &lt;figure class=&#34;highlight bash&#34;&gt;&lt;figcaption&gt;&lt;span&gt;bash&lt;/span&gt;&lt;/figcaption&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;6&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;7&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;var parseImage = &lt;span class=&#34;keyword&#34;&gt;function&lt;/span&gt;(img, size) &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;   &lt;span class=&#34;keyword&#34;&gt;if&lt;/span&gt; (img.startsWith(&lt;span class=&#34;string&#34;&gt;&amp;#x27;//&amp;#x27;&lt;/span&gt;) || img.startsWith(&lt;span class=&#34;string&#34;&gt;&amp;#x27;http&amp;#x27;&lt;/span&gt;)) &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;     &lt;span class=&#34;built_in&#34;&gt;return&lt;/span&gt; img&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;   &amp;#125; &lt;span class=&#34;keyword&#34;&gt;else&lt;/span&gt; &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;     &lt;span class=&#34;built_in&#34;&gt;return&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;&amp;#x27;https://tva&amp;#x27;&lt;/span&gt;+randomServer+&lt;span class=&#34;string&#34;&gt;&amp;#x27;.sinaimg.cn/&amp;#x27;&lt;/span&gt;+size+&lt;span class=&#34;string&#34;&gt;&amp;#x27;/&amp;#x27;&lt;/span&gt;+img //替换成自己Github图床前链&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;   &amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt; &amp;#125;&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;/p&gt;
&lt;p&gt;如下修改&lt;br /&gt;
 &lt;figure class=&#34;highlight bash&#34;&gt;&lt;figcaption&gt;&lt;span&gt;bash&lt;/span&gt;&lt;/figcaption&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;6&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;7&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;var parseImage = &lt;span class=&#34;keyword&#34;&gt;function&lt;/span&gt;(img, size) &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;   &lt;span class=&#34;keyword&#34;&gt;if&lt;/span&gt; (img.startsWith(&lt;span class=&#34;string&#34;&gt;&amp;#x27;//&amp;#x27;&lt;/span&gt;) || img.startsWith(&lt;span class=&#34;string&#34;&gt;&amp;#x27;http&amp;#x27;&lt;/span&gt;)) &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;     &lt;span class=&#34;built_in&#34;&gt;return&lt;/span&gt; img&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;   &amp;#125; &lt;span class=&#34;keyword&#34;&gt;else&lt;/span&gt; &amp;#123;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;     &lt;span class=&#34;built_in&#34;&gt;return&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;&amp;#x27;https://raw.githubusercontent.com/UI123456ax/PicGo/main/ACG-img/&amp;#x27;&lt;/span&gt;+img&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;   &amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt; &amp;#125;&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;/p&gt;
&lt;p&gt;复制所有 Github 图片链接&lt;br /&gt;
&lt;img data-src=&#34;https://raw.githubusercontent.com/UI123456ax/PicGo/main/Blog/%E5%9B%BE%E5%BA%8A%E4%BF%AE%E5%A4%8D%20(1).png&#34; alt=&#34;&#34; /&gt;&lt;/p&gt;
&lt;p&gt;新建一个空白文本文档.txt&lt;br /&gt;
 把复制的链接粘贴到文本中，CTRL+H 打开替换&lt;br /&gt;
替换内容：&lt;br /&gt;
 &lt;code&gt;https://raw.githubusercontent.com/用户名/仓库名/main/仓库文件夹/&lt;/code&gt; &lt;br /&gt;
 替换为：&lt;br /&gt;
 &lt;code&gt;- &lt;/code&gt; &lt;br /&gt;
&lt;strong&gt;注意在 - 之后要加上空格！&lt;/strong&gt;&lt;br /&gt;
&lt;img data-src=&#34;https://github.com/UI123456ax/PicGo/blob/main/Blog/%E5%9B%BE%E5%BA%8A%E4%BF%AE%E5%A4%8D%20(2).png?raw=true&#34; alt=&#34;&#34; /&gt;&lt;br /&gt;
全部替换&lt;/p&gt;
